@model List<AgenciaDeToursRD.Models.Pais>

@{
    ViewData["Title"] = "Listado de Países";
    Layout = "_Layout";
}

<div class="container py-5">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-flag-fill me-2"></i>Listado de Países
        </h2>
        <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Agregar País
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle me-2"></i>No hay países registrados aún.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var pais in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 position-relative hover-card">
                        @if (!string.IsNullOrEmpty(pais.Bandera))
                        {
                            <img src="@pais.Bandera"
                                 class="card-img-top rounded-top"
                                 style="object-fit: cover; height: 200px;"
                                 alt="Bandera de @pais.Nombre" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-light rounded-top" style="height: 200px;">
                                <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
                            </div>
                        }

                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold">@pais.Nombre</h5>
                            <p class="card-text text-muted">
                                <i class="bi bi-geo-alt-fill me-1"></i>
                                <strong>@(pais.Destinos?.Count() ?? 0)</strong> destinos registrados
                            </p>
                        </div>

                        <div class="card-footer bg-white border-top-0 d-flex justify-content-center gap-2">
                            <a asp-action="Details" asp-route-id="@pais.ID" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@pais.ID" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button class="btn btn-outline-danger btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal"
                                    data-id="@pais.ID"
                                    data-nombre="@pais.Nombre">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal de eliminación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="bi bi-trash-fill me-2"></i>Confirmar eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body text-center">
                ¿Estás seguro de que deseas eliminar el país <strong id="paisNombre"></strong>?
            </div>
            <div class="modal-footer justify-content-center">
                <form id="deleteForm" method="post">
                    <input type="hidden" name="id" id="paisId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const paisId = button.getAttribute('data-id');
            const paisNombre = button.getAttribute('data-nombre');

            deleteModal.querySelector('#paisNombre').textContent = paisNombre;
            deleteModal.querySelector('#paisId').value = paisId;
            deleteModal.querySelector('#deleteForm').action = `/Paises/Delete/${paisId}`;
        });
    </script>
    <style>
        .hover-card:hover {
            transform: translateY(-5px);
            transition: transform 0.3s ease;
        }
    </style>
}
